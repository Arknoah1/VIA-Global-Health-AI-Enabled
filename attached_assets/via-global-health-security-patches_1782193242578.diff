+// Allow-list sanitizer for any externally-sourced string that ends up as a
+// filesystem path segment (e.g. the scraped SKU). Strips everything except
+// alphanumerics, dot, underscore, and hyphen — no '/', '\', or '..' can
+// survive this, so it can never escape the intended base directory.
+function sanitizeForPath(value: string): string {
+  return (value || '')
+    .replace(/[^a-zA-Z0-9._-]/g, '-')
+    .replace(/-+/g, '-')
+    .replace(/^[.-]+|[.-]+$/g, '')
+    .substring(0, 80);
+}
